# ---- Brevo SMTP (transactional email) ----
# Brevo dashboard -> SMTP & API -> SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=xxxxxx@smtp-brevo.com
SMTP_PASS=xsmtpsib-your-smtp-key-here

# The "from" address. MUST be a verified sender / domain in Brevo, or sends are rejected.
FROM_EMAIL=noreply@misterytrips.com
FROM_NAME=MisteryTrips

# Where the internal "new submission" notification is delivered.
ADMIN_EMAIL=hr@draconx.com

# Used for links inside emails (the welcome CTA). Your real domain in production.
SITE_URL=https://misterytrips.com

# ---- Server ----
PORT=3000
